/* PP Radio Grotesk — primary sans (body, UI, product names) */
@font-face {
  font-family: 'PP Radio Grotesk';
  src: url('{{ 'PPRadioGrotesk-Ultralight.woff' | asset_url }}') format('woff');
  font-weight: 200;
  font-style: normal;
  font-display: swap;
}
