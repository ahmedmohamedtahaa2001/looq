{%- comment -%}
  LOOQ — The Bundles section (pixel-matched to Figma `126:5067`)
  3 cards: 1 featured purple "BEST VALUE" + 2 default white-bordered.
  Each card is absolute-positioned per Figma coordinates.
{%- endcomment -%}

<section class="looq-bundles" data-section-id="{{ section.id }}">
  <div class="looq-bundles__list" role="list">
    {%- for block in section.blocks -%}
      {%- comment -%}
        Resolve the linked product so title/price/image come from the live
        product record instead of the section block setting. `block.settings.product_handle`
        is the source of truth; `block.settings.title`/`price`/etc remain
        as fallbacks when no handle is set (or the handle doesn't resolve).
      {%- endcomment -%}
      {%- assign bundle_product = blank -%}
      {%- if block.settings.product_handle != blank -%}
        {%- assign bundle_product = all_products[block.settings.product_handle] -%}
      {%- endif -%}

      {%- comment -%}
        Per-field fallback: each piece of data prefers the live product
        record, but falls back to the block setting when the product
        record's field is empty or zero. This handles bundle products
        that exist in admin but don't have a price/compare-at set yet.
      {%- endcomment -%}
      {%- if bundle_product != blank and bundle_product.title != blank -%}
        {%- assign b_title = bundle_product.title | upcase -%}
      {%- else -%}
        {%- assign b_title = block.settings.title -%}
      {%- endif -%}

      {%- if bundle_product != blank and bundle_product.price > 0 -%}
        {%- assign b_price_num = bundle_product.price | divided_by: 100.0 | round: 0 -%}
        {%- assign b_price = 'LE ' | append: b_price_num -%}
      {%- else -%}
        {%- assign b_price = block.settings.price -%}
      {%- endif -%}

      {%- assign b_compare = '' -%}
      {%- if bundle_product != blank and bundle_product.compare_at_price > bundle_product.price and bundle_product.compare_at_price > 0 -%}
        {%- assign b_compare_num = bundle_product.compare_at_price | divided_by: 100.0 | round: 0 -%}
        {%- assign b_compare = 'LE ' | append: b_compare_num -%}
      {%- elsif block.settings.compare_at != blank -%}
        {%- assign b_compare = block.settings.compare_at -%}
      {%- endif -%}

      {%- if bundle_product != blank and bundle_product.featured_image != blank -%}
        {%- assign b_image = bundle_product.featured_image -%}
      {%- else -%}
        {%- assign b_image = block.settings.image -%}
      {%- endif -%}

      {%- if bundle_product != blank -%}
        {%- assign b_url = bundle_product.url -%}
      {%- else -%}
        {%- assign b_url = block.settings.url | default: '#' -%}
      {%- endif -%}

      <article class="looq-bundles__card looq-bundles__card--{{ block.settings.style }}" {{ block.shopify_attributes }} role="listitem">
        <div class="looq-bundles__media">
          {%- if b_image != blank -%}
            <img src="{{ b_image | image_url: width: 320 }}" alt="{{ b_title | escape }}" loading="lazy">
          {%- else -%}
            <img src="{{ block.settings.image_default | default: 'looq-bundle-product-1.png' | asset_url }}" alt="{{ b_title | escape }}" loading="lazy">
          {%- endif -%}
        </div>

        {%- if block.settings.badge != blank -%}
          <span class="looq-bundles__badge">{{ block.settings.badge }}</span>
        {%- endif -%}

        <h3 class="looq-bundles__title">{{ b_title }}</h3>

        {%- if block.settings.subtitle != blank -%}
          <p class="looq-bundles__subtitle">{{ block.settings.subtitle }}</p>
        {%- endif -%}

        <div class="looq-bundles__price-row">
          <span class="looq-bundles__price">{{ b_price }}</span>
          {%- if b_compare != blank -%}
            <s class="looq-bundles__compare">{{ b_compare }}</s>
          {%- endif -%}
        </div>

        <a class="looq-bundles__add" href="{{ b_url }}">ADD</a>
      </article>
    {%- endfor -%}
  </div>
</section>

{% stylesheet %}
.looq-bundles { position:relative; width:100%; margin:0 auto;
  background:#fff; padding:32px 0 28px; }
.looq-bundles__list { display:flex; flex-direction:column;
  list-style:none; margin:0; padding:0; gap:11px; align-items:center; }

/* ── Card base ── */
.looq-bundles__card { position:relative; box-sizing:border-box;
  width:351px; padding:0; overflow:visible; }
.looq-bundles__card--featured { background:#8556e0; height:160px; }
.looq-bundles__card--default  { background:#fff; height:168px;
  border:2px solid rgba(113,110,110,0.39); }
/* Card 3 is shorter than Card 2 — index-based override (3rd default card) */
.looq-bundles__card--default + .looq-bundles__card--default { height:165px; }

/* ── Photo (absolute, allowed to overflow above) ── */
.looq-bundles__media { position:absolute; pointer-events:none;
  display:flex; align-items:center; justify-content:center; }
.looq-bundles__card--featured .looq-bundles__media { left:13px; top:-18px; width:103px; height:155px; }
.looq-bundles__card--default  .looq-bundles__media { left:10px; top:-16px; width:102px; height:152px; }
.looq-bundles__card--default + .looq-bundles__card--default .looq-bundles__media { left:6px; top:-27px; width:105px; height:158px; }
.looq-bundles__media img { width:100%; height:100%; object-fit:contain; object-position:center; }

/* ── Badge (Card 1 only) ── */
.looq-bundles__badge { position:absolute; left:127px; top:34px;
  display:inline-flex; align-items:center; justify-content:center;
  width:64px; height:18px; background:#edfc4d; color:#3b2a71;
  font-family:var(--font-body); font-weight:400;
  font-size:7px; line-height:1; letter-spacing:1.19px;
  text-transform:uppercase; }

/* ── Title ── */
.looq-bundles__title { position:absolute; margin:0; padding:0;
  font-family:var(--font-product); font-weight:900;
  font-size:20px; line-height:1; text-transform:uppercase;
  white-space:nowrap; }
.looq-bundles__card--featured .looq-bundles__title { left:125px; top:55px; color:#fff; }
.looq-bundles__card--default  .looq-bundles__title { left:126px; top:46px; color:#1e1e1e; white-space:normal; }
.looq-bundles__card--default + .looq-bundles__card--default .looq-bundles__title { top:38px; white-space:nowrap; }

/* ── Subtitle ── */
/* Spacing reworked per Image #114: extra room between title and subtitle
   (gap was ~6-12px; bumped to ~16-18px). Subtitle text rendered with
   "•" separators between each product. ml sizes dropped — they live in
   the product description. */
.looq-bundles__subtitle { position:absolute; margin:0; padding:0;
  font-family:var(--font-body); font-weight:400; line-height:1.4;
  white-space:nowrap; }
.looq-bundles__card--featured .looq-bundles__subtitle { left:125px; top:84px;
  font-size:8px; color:rgba(255,255,255,0.82); letter-spacing:0.4px; }
.looq-bundles__card--default  .looq-bundles__subtitle { left:126px; top:96px;
  font-size:9px; color:#1e1e1e; letter-spacing:0.4px; }
.looq-bundles__card--default + .looq-bundles__card--default .looq-bundles__subtitle { top:66px; }

/* ── Price + compare-at ── */
.looq-bundles__price-row { position:absolute; left:28px;
  display:inline-flex; align-items:baseline; gap:14px; }
.looq-bundles__card--featured .looq-bundles__price-row { top:127px; }
.looq-bundles__card--default  .looq-bundles__price-row { left:29px; top:136px; }
.looq-bundles__card--default + .looq-bundles__card--default .looq-bundles__price-row { top:138px; }

.looq-bundles__price { font-family:var(--font-product); font-weight:900;
  font-size:20px; line-height:1; }
.looq-bundles__card--featured .looq-bundles__price { color:#fff; }
.looq-bundles__card--default  .looq-bundles__price { color:#1e1e1f; }

.looq-bundles__compare { font-family:var(--font-body); font-weight:400;
  font-size:10px; line-height:1; text-decoration:line-through;
  text-decoration-skip-ink:none; }
.looq-bundles__card--featured .looq-bundles__compare { color:rgba(255,245,245,0.92); }
.looq-bundles__card--default  .looq-bundles__compare { color:#ff5c00; }

/* ── ADD button ── */
.looq-bundles__add { position:absolute; left:265px;
  display:inline-flex; align-items:center; justify-content:center;
  width:65px; height:22px;
  font-family:var(--font-body); font-weight:400;
  font-size:10px; line-height:1; letter-spacing:1.7px;
  text-transform:uppercase; text-decoration:none; }
.looq-bundles__card--featured .looq-bundles__add { top:128px; left:265px;
  background:#3b2a71; color:#fff; }
.looq-bundles__card--default  .looq-bundles__add { top:127px; left:266px;
  background:transparent; color:rgba(30,30,30,0.7);
  border:1px solid rgba(30,30,30,0.71); }
.looq-bundles__card--default + .looq-bundles__card--default .looq-bundles__add { top:126px; }
{% endstylesheet %}

{% schema %}
{
  "name": "The Bundles",
  "tag": "section",
  "class": "section--looq-bundles",
  "blocks": [
    {
      "type": "bundle",
      "name": "Bundle",
      "limit": 6,
      "settings": [
        { "type": "select", "id": "style", "label": "Style", "default": "default",
          "options": [
            { "value": "featured", "label": "Featured (purple, BEST VALUE)" },
            { "value": "default",  "label": "Default (white, bordered)" }
          ] },
        { "type": "text", "id": "product_handle", "label": "Linked product handle",
          "info": "When set, title / price / image / link are pulled from this product so admin edits appear here automatically. Leave blank to use the static fields below." },
        { "type": "text", "id": "badge", "label": "Badge (e.g. BEST VALUE)" },
        { "type": "text", "id": "title", "label": "Title (fallback)", "default": "THE BĀTHTUB SET" },
        { "type": "text", "id": "subtitle", "label": "Subtitle (sizes/contents)" },
        { "type": "text", "id": "price", "label": "Price", "default": "LE 1500" },
        { "type": "text", "id": "compare_at", "label": "Compare-at price (strikethrough)" },
        { "type": "image_picker", "id": "image", "label": "Photo" },
        { "type": "text", "id": "image_default", "label": "Demo image filename", "default": "looq-bundle-product-1.png" },
        { "type": "url", "id": "url", "label": "Link" }
      ]
    }
  ],
  "presets": [{
    "name": "The Bundles",
    "category": "LOOQ",
    "blocks": [
      { "type": "bundle", "settings": { "style": "featured", "badge": "BEST VALUE", "title": "THE BĀTHTUB SET", "subtitle": "BÖDI WÖSH • HĀND WÖSH • BÖDI LÖSHN", "price": "LE 1200", "compare_at": "LE 1800", "image_default": "looq-bundle-product-1.png" } },
      { "type": "bundle", "settings": { "style": "default",  "title": "THE MINI BĀTHTUB SET", "subtitle": "BÖDI WÖSH • BÖDI LÖSHN", "price": "LE 1200", "compare_at": "LE 1500", "image_default": "looq-bundle-product-2.png" } },
      { "type": "bundle", "settings": { "style": "default",  "title": "THE BĀTHTUB", "subtitle": "STORAGE AREA • SMALL • LARGE", "price": "LE 800", "image_default": "looq-bundle-product-3.png" } }
    ]
  }]
}
{% endschema %}
