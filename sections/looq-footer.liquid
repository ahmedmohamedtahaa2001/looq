{%- comment -%}
  LOOQ — Footer section (pixel-matched to Figma `222:29`, y=6409..6711)
  Brand (logo wordmark + Migra italic tagline) → 3 link columns
  → bottom row (legal copy + powered-by  |  social icons + lang)
  Resync token: phase4-v2 (Powered-by removal + auto-link wiring)
{%- endcomment -%}

<section class="looq-footer" data-section-id="{{ section.id }}">
  <div class="looq-footer__inner">

    <div class="looq-footer__brand">
      <img class="looq-footer__logo" src="{{ 'looq-logo-footer.png' | asset_url }}" alt="LOOQ" width="78" height="26">
      <p class="looq-footer__tagline">also called yours</p>
    </div>

    <nav class="looq-footer__cols" aria-label="Footer">
      {%- for block in section.blocks -%}
        {%- if block.type == 'column' -%}
          <details class="looq-footer__col looq-footer__col--{{ forloop.index }}" {{ block.shopify_attributes }}>
            <summary class="looq-footer__heading">
              <span class="looq-footer__heading-text">{{ block.settings.heading }}</span>
              <span class="looq-footer__chev" aria-hidden="true">
                <svg width="11" height="7" viewBox="0 0 11 7" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M1.5 1.5l4 4 4-4"/>
                </svg>
              </span>
            </summary>
            <div class="looq-footer__items">
              {%- assign items = block.settings.items | newline_to_br | split: '<br />' -%}
              {%- for item in items -%}
                {%- assign item_clean = item | strip -%}
                {%- if item_clean != blank -%}
                  {%- comment -%}
                    Auto-link known labels: footer policy/contact items get
                    wired to their canonical Shopify URLs. Unknown text
                    stays as plain text.
                  {%- endcomment -%}
                  {%- assign item_lower = item_clean | downcase -%}
                  {%- assign link_url = '' -%}
                  {%- if item_lower == 'terms of service' -%}{%- assign link_url = '/pages/terms-of-service' -%}
                  {%- elsif item_lower == 'shipping policy' -%}{%- assign link_url = '/pages/shipping-policy' -%}
                  {%- elsif item_lower == 'privacy policy' -%}{%- assign link_url = '/pages/privacy-policy' -%}
                  {%- elsif item_lower == 'refund policy' -%}{%- assign link_url = '/pages/refund-policy' -%}
                  {%- elsif item_lower == 'our story' -%}{%- assign link_url = '/pages/our-story' -%}
                  {%- elsif item_lower == 'faq' -%}{%- assign link_url = '/pages/faq' -%}
                  {%- elsif item_lower contains '@' -%}{%- assign link_url = 'mailto:' | append: item_clean -%}
                  {%- endif -%}
                  {%- comment -%}
                    "Business" and "Connect" open the drawer sub-panel of the
                    same name instead of navigating to a page. data-menu-trigger
                    opens the drawer; data-menu-open-panel tells the drawer JS
                    which sub-panel to switch to once open.
                  {%- endcomment -%}
                  {%- if item_lower == 'business' or item_lower == 'connect' -%}
                    <p class="looq-footer__item">
                      <button type="button" class="looq-footer__link looq-footer__link--menu"
                              data-menu-trigger
                              data-menu-open-panel="{{ item_lower }}">{{ item_clean }}</button>
                    </p>
                  {%- elsif link_url != '' -%}
                    <p class="looq-footer__item"><a class="looq-footer__link" href="{{ link_url }}">{{ item_clean }}</a></p>
                  {%- else -%}
                    <p class="looq-footer__item">{{ item_clean }}</p>
                  {%- endif -%}
                {%- endif -%}
              {%- endfor -%}
            </div>
          </details>
        {%- endif -%}
      {%- endfor -%}
    </nav>

    <div class="looq-footer__base">
      <div class="looq-footer__legal">
        <p class="looq-footer__copy">
          {{ section.settings.copy_line1 | default: 'Copyright © 2026 LOOQ Inc.' }}<br>
          {{ section.settings.copy_line2 | default: 'All rights reserved.' }}
        </p>
        {%- if section.settings.powered != blank -%}
          <p class="looq-footer__powered">{{ section.settings.powered }}</p>
        {%- endif -%}
      </div>

      <div class="looq-footer__meta">
        <ul class="looq-footer__social" role="list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'social' -%}
              {%- assign platform_handle = block.settings.platform | downcase -%}
              {%- if platform_handle contains 'face' -%}{%- assign icon = 'looq-footer-social-fb.svg' -%}
              {%- elsif platform_handle contains 'insta' -%}{%- assign icon = 'looq-footer-social-ig.svg' -%}
              {%- elsif platform_handle contains 'tik' -%}{%- assign icon = 'looq-footer-social-tt.svg' -%}
              {%- else -%}{%- assign icon = 'looq-footer-social-fb.svg' -%}{%- endif -%}
              <li><a href="{{ block.settings.url }}" aria-label="{{ block.settings.platform }}" {{ block.shopify_attributes }}>
                <img src="{{ icon | asset_url }}" alt="" width="18" height="18">
              </a></li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
        <div class="looq-footer__lang">
          <img class="looq-footer__flag" src="{{ 'looq-flag-uk.png' | asset_url }}" alt="" width="16" height="10">
          <span class="looq-footer__lang-code">EN</span>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  /* Footer accordion behavior is mobile-only. On ≥768px the columns are laid
     out side-by-side and we force-open the <details> elements so all items
     render. The matchMedia listener keeps the state correct if the user
     resizes (e.g. rotating a tablet). */
  (function () {
    var mq = window.matchMedia('(min-width: 768px)');
    var details = document.querySelectorAll('.looq-footer__col');
    function sync() {
      details.forEach(function (d) {
        if (mq.matches) d.setAttribute('open', '');
        else d.removeAttribute('open');
      });
    }
    sync();
    if (mq.addEventListener) mq.addEventListener('change', sync);
    else mq.addListener(sync);
  })();
</script>

{% stylesheet %}
.looq-footer { width:100%; margin:0 auto;
  background:#d9d9d9; padding:26px 0 26px;
  font-family:var(--font-body); }
.looq-footer__inner { padding:0 13px; }

.looq-footer__brand { margin:0 0 35px; }
.looq-footer__logo { display:block; width:78px; height:26px; }
.looq-footer__tagline { margin:0; padding:0;
  font-family:var(--font-italic-display); font-style:italic; font-weight:200;
  font-size:12px; line-height:25px; color:#000; }

/* Columns stack vertically as collapsible <details> accordions (per Image #102 mobile design).
   Each column = one accordion tab; tap heading to expand/collapse. */
.looq-footer__cols { display:flex; flex-direction:column; margin:0 0 21px; padding:0; gap:0; }
.looq-footer__col {
  padding:0; margin:0;
  width:100%;
  border-bottom:1px solid rgba(23,23,23,0.12);
}
.looq-footer__col:last-of-type { border-bottom:0; }

.looq-footer__heading {
  list-style:none;
  display:flex; align-items:center; justify-content:space-between;
  margin:0; padding:14px 0;
  font-family:var(--font-product); font-weight:900;
  font-size:13px; line-height:1; color:#ff5c00;
  text-transform:capitalize;
  white-space:nowrap;
  cursor:pointer;
  user-select:none;
}
.looq-footer__heading::-webkit-details-marker,
.looq-footer__heading::marker { display:none; content:''; }
.looq-footer__chev {
  display:inline-flex; align-items:center; justify-content:center;
  width:16px; height:16px;
  color:#ff5c00;
  transition:transform 220ms ease;
}
.looq-footer__col[open] .looq-footer__chev { transform:rotate(180deg); }

.looq-footer__items {
  padding:0 0 14px;
  display:flex; flex-direction:column; gap:4px;
}
.looq-footer__item { margin:0; padding:0;
  font-family:var(--font-body); font-weight:400;
  font-size:11px; line-height:22px; color:rgba(23,23,23,0.61);
  text-transform:capitalize; }
.looq-footer__col--2 .looq-footer__item { text-transform:none; }
.looq-footer__link { color:inherit; text-decoration:none; transition:color 160ms ease; }
.looq-footer__link:hover, .looq-footer__link:focus { color:#ff5c00; text-decoration:underline; }
/* Button-style menu trigger (Business / Connect) -- look identical to <a>. */
.looq-footer__link--menu {
  background:transparent; border:0; padding:0; margin:0;
  font:inherit; cursor:pointer; text-align:left;
}

.looq-footer__base { display:flex; align-items:flex-start;
  justify-content:space-between; gap:12px; }
.looq-footer__legal { display:flex; flex-direction:column; gap:14px; }
.looq-footer__copy { margin:0; padding:0;
  font-size:11px; line-height:1.18; color:rgba(23,23,23,0.61); }
.looq-footer__powered { margin:0; padding:0;
  font-size:11px; line-height:1; color:#ff5c00; }

.looq-footer__meta { display:flex; flex-direction:column;
  align-items:flex-start; gap:13px; }
.looq-footer__social { list-style:none; margin:0; padding:0;
  display:inline-flex; gap:5px; }
.looq-footer__social a { display:inline-flex; align-items:center; justify-content:center;
  width:18px; height:18px; }
.looq-footer__social img { display:block; width:18px; height:18px; }

.looq-footer__lang { display:inline-flex; align-items:center; gap:4px; }
.looq-footer__flag { display:block; width:16px; height:10px;
  border-radius:2px; object-fit:cover; }
.looq-footer__lang-code { font-family:var(--font-product); font-weight:900;
  font-size:11px; line-height:1; color:rgba(23,23,23,0.61);
  text-transform:uppercase; }
{% endstylesheet %}

{% schema %}
{
  "name": "Footer",
  "tag": "section",
  "class": "section--looq-footer",
  "settings": [
    { "type": "text", "id": "copy_line1", "label": "Copyright line 1", "default": "Copyright © 2026 LOOQ Inc." },
    { "type": "text", "id": "copy_line2", "label": "Copyright line 2", "default": "All rights reserved." },
    { "type": "text", "id": "powered",    "label": "Powered by (clear to hide)" }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Link column",
      "limit": 3,
      "settings": [
        { "type": "text",     "id": "heading", "label": "Heading", "default": "Info" },
        { "type": "textarea", "id": "items",   "label": "Links (one per line)",
          "default": "Terms of Service\nShipping Policy\nPrivacy Policy\nRefund Policy" }
      ]
    },
    {
      "type": "social",
      "name": "Social",
      "limit": 6,
      "settings": [
        { "type": "text", "id": "platform", "label": "Platform", "default": "Facebook" },
        { "type": "url",  "id": "url",      "label": "URL" }
      ]
    }
  ],
  "presets": [{
    "name": "Footer",
    "category": "LOOQ",
    "blocks": [
      { "type": "column", "settings": { "heading": "Info",        "items": "Terms of Service\nShipping Policy\nPrivacy Policy\nRefund Policy" } },
      { "type": "column", "settings": { "heading": "Contact Us:", "items": "info@looqcosmetics.com\nResponse Time:\n24–48 hours\nCairo, Egypt" } },
      { "type": "column", "settings": { "heading": "Need Help?",  "items": "Our Story\nBusiness\nConnect\nFAQ" } },
      { "type": "social", "settings": { "platform": "Facebook" } },
      { "type": "social", "settings": { "platform": "Instagram" } },
      { "type": "social", "settings": { "platform": "TikTok" } }
    ]
  }]
}
{% endschema %}
