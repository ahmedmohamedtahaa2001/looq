{%- comment -%}
  LOOQ — Menu drawer (main menu + The Goods sub-menu)
  Pixel-matched to Figma nodes 10:34 (main) and 99:1427 (Goods).
  Renders globally via header-group.json. Hidden until [data-menu-trigger] click.
{%- endcomment -%}

<div class="looq-menu" id="looq-menu" role="dialog" aria-modal="true" aria-hidden="true" aria-label="Site menu" data-section-id="{{ section.id }}">
  <div class="looq-menu__backdrop" data-menu-close></div>

  <div class="looq-menu__sheet" role="document">
    {%- comment -%} Top photo + marquee + close X (shared across both panels) {%- endcomment -%}
    {%- if section.settings.image != blank -%}
      {%- assign menu_photo_url = section.settings.image | image_url: width: 800 -%}
    {%- else -%}
      {%- assign menu_photo_url = 'looq-menu-photo.jpg' | asset_url -%}
    {%- endif -%}
    <div class="looq-menu__top" style="background-image:url('{{ menu_photo_url }}')">
      <button type="button" class="looq-menu__close" data-menu-close aria-label="Close menu">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M1 1l12 12M13 1L1 13" stroke="#1e1e1f" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </button>
    </div>
    <div class="looq-menu__marquee" aria-hidden="true">
      <div class="looq-menu__marquee-track">
        {%- for i in (1..16) -%}
          <span class="looq-menu__marquee-text">also called yours</span>
          <img class="looq-menu__marquee-arrow" src="{{ 'looq-marquee-icon.png' | asset_url }}" width="12" height="6" alt="" aria-hidden="true">
        {%- endfor -%}
      </div>
    </div>

    {%- comment -%} Panel 1: Main menu {%- endcomment -%}
