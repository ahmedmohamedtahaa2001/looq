{%- comment -%}
  LOOQ — Support page (Figma 110:2379, 390 × 962)
  Pattern A: orange hero + contact form.
{%- endcomment -%}

<section class="looq-page looq-page--support" data-section-id="{{ section.id }}">
  <div class="looq-page__hero">
    <div class="looq-page__watermark" aria-hidden="true">{% render 'looq-infinity' %}</div>
    <h1 class="looq-page__title">SUPPORT</h1>
  </div>

  <div class="looq-page__body">
    <h2 class="looq-page__heading">HOW CAN<br>WE HELP?</h2>
    <p class="looq-page__intro">If you need help with an order, product,<br>or delivery, our team is here.</p>

    {% form 'contact' %}
      <h3 class="looq-page__form-heading">Support Request Form</h3>

      <label class="looq-page__field">
        <span>Full Name</span>
        <input type="text" name="contact[name]" placeholder="Enter your full name" required>
      </label>

      <label class="looq-page__field">
        <span>Email Address</span>
        <input type="email" name="contact[email]" placeholder="Enter your email address" required>
      </label>

      <label class="looq-page__field">
        <span>Order Number</span>
        <input type="text" name="contact[order_number]" placeholder="Order #12345">
      </label>

      <label class="looq-page__field">
        <span>How can we help?</span>
        <textarea name="contact[body]" rows="5" placeholder="Write your message here..." required></textarea>
      </label>

      {%- if form.posted_successfully? -%}
        <p class="looq-page__form-success">Thanks — we'll get back to you within 24-48 hours.</p>
      {%- endif -%}

      <button type="submit" class="looq-page__submit">Submit Request</button>
    {% endform %}

    <h3 class="looq-page__form-heading looq-page__form-heading--secondary">Additional Help</h3>
    <p class="looq-page__alt-help">You may also find quick answers in:</p>
    <div class="looq-page__chips">
      <a class="looq-page__chip" href="/pages/faq">FAQ</a>
      <a class="looq-page__chip" href="/pages/contact-us">CONTACT US</a>
    </div>
  </div>
</section>

{% stylesheet %}
.looq-page { width:100%; max-width:390px; margin:0 auto; background:#fff; }
.looq-page--support { --page-accent:#ff5c00; }
.looq-page__hero { position:relative; overflow:hidden; }
.looq-page__watermark {
  /* Watermark uses CSS mask-image of the LOOQ ∞ icon — color property
     drives the tint via the masked element's background-color: currentColor.
     420×230 keeps the icon's natural 453:249 aspect ratio. White at 18%
     alpha sits on top of the colored hero as a darker tonal layer. */
  position:absolute; right:-60px; top:50%; transform:translateY(-50%);
  width:420px; height:230px; pointer-events:none; user-select:none;
  color: rgba(255, 255, 255, 0.18);
}
.looq-page__hero { width:100%; height:279px; background:var(--page-accent);
  display:flex; align-items:center;
  padding:77px 19px 0; }
.looq-page__title { margin:0; padding:0;
  font-family:var(--font-display, 'ABC Repro Ultra', sans-serif); font-weight:950;
  font-size:45px; white-space:nowrap; line-height:1; color:#fff; text-transform:uppercase; }
.looq-page__body { padding:24px 19px 36px; }
.looq-page__heading { margin:0 0 16px; padding:0;
  font-family:var(--font-display, 'ABC Repro Ultra', sans-serif); font-weight:950;
  font-size:32px; line-height:1; color:#1e1e1e; text-transform:uppercase; }
.looq-page__intro { margin:0 0 24px; padding:0;
  font-family:var(--font-body); font-size:11px; line-height:1.34;
  color:rgba(30,30,30,0.49); }
.looq-page__form-heading { margin:0 0 16px; padding:0;
  font-family:var(--font-product); font-weight:900;
  font-size:13px; line-height:25px; color:var(--page-accent);
  text-transform:capitalize; }
.looq-page__form-heading--secondary { margin-top:32px; }
.looq-page__field { display:block; margin:0 0 16px; }
.looq-page__field span { display:block; margin:0 0 6px;
  font-family:var(--font-body); font-size:11px; line-height:1.34;
  color:var(--page-accent); }
.looq-page__field input,
.looq-page__field textarea { display:block; width:243px; max-width:100%;
  padding:6px 11px; box-sizing:border-box;
  font-family:var(--font-body); font-size:11px; line-height:1.34;
  color:#1e1e1e; background:#fff;
  border:1px solid rgba(183,181,181,0.48); border-radius:0; }
.looq-page__field input { height:26px; }
.looq-page__field textarea { height:130px; resize:vertical; }
.looq-page__field input::placeholder,
.looq-page__field textarea::placeholder { color:rgba(30,30,30,0.47); }
.looq-page__submit { display:inline-flex; align-items:center; justify-content:center;
  width:101px; height:26px; padding:0; border:0;
  background:var(--page-accent); color:#fff; cursor:pointer;
  font-family:var(--font-body); font-size:11px; line-height:1.34; }
.looq-page__form-success { margin:8px 0 0; font-family:var(--font-body);
  font-size:11px; color:#1e1e1e; }
.looq-page__alt-help { margin:0 0 8px; padding:0;
  font-family:var(--font-body); font-size:11px; line-height:1.34;
  color:rgba(30,30,30,0.47); }
.looq-page__chips { display:flex; gap:12px; }
.looq-page__chip { display:inline-flex; align-items:center; justify-content:center;
  height:26px; padding:0 13px;
  font-family:var(--font-body); font-size:11px; line-height:1;
  color:var(--page-accent); border:1px solid var(--page-accent);
  text-decoration:none; }
.looq-page__title { white-space:nowrap; }
{% endstylesheet %}

{% schema %}
{
  "name": "LOOQ Support",
  "settings": [],
  "presets": [{ "name": "LOOQ Support", "category": "LOOQ" }]
}
{% endschema %}
