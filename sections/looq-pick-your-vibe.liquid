{%- comment -%}
  LOOQ — Pick Your Vibe section
  4 colored stripes (pink/yellow/teal/purple) with flavor names + descriptions + arrow.
  Y-range in Figma: 2968..3696 (~728 px) — Rectangle 11 (101:2102) is the wrapper.
{%- endcomment -%}

<section class="looq-pyv" data-section-id="{{ section.id }}">
  <div class="looq-pyv__inner">
    {%- comment -%} Headline is rendered at the END of Best Sellers section in Figma
        (node 101:2125 "PICK YOUR VIBE."), so this section starts with the stripes. {%- endcomment -%}
    {%- if section.settings.show_headline -%}
    <h2 class="looq-pyv__headline">
      <span>{{ section.settings.headline_1 | default: 'PICK' }}</span>
      <span>{{ section.settings.headline_2 | default: 'YOUR VIBE.' }}</span>
    </h2>
    {%- endif -%}

    <ul class="looq-pyv__list" role="list">
      {%- for block in section.blocks -%}
        <li class="looq-pyv__stripe" style="background:{{ block.settings.color }}" {{ block.shopify_attributes }}>
          <a class="looq-pyv__link" href="{{ block.settings.url | default: '#' }}" aria-label="{{ block.settings.title }}">
            <h3 class="looq-pyv__title">
              {%- assign title_words = block.settings.title | split: ' ' -%}
              {%- for word in title_words -%}<span>{{ word }}</span>{%- endfor -%}
            </h3>
            <p class="looq-pyv__desc">{{ block.settings.description }}</p>
            <span class="looq-pyv__arrow" aria-hidden="true">
              <svg width="33" height="14" viewBox="0 0 33 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M1 7H30M30 7L24 1M30 7L24 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </a>
        </li>
      {%- endfor -%}
    </ul>
  </div>
</section>

{% stylesheet %}
.looq-pyv { position:relative; width:100%; margin:0 auto; background:#fff; padding:0; }
.looq-pyv__inner { padding-inline:22px; }
.looq-pyv__headline {
  margin:0 0 24px; padding:0;
  font-family:var(--font-display); font-weight:950;
  font-size:36px; line-height:1; color:#6749c4;
  text-transform:uppercase; white-space:nowrap;
}
.looq-pyv__headline span { display:block; }
.looq-pyv__list { list-style:none; margin:0; padding:0;
  display:flex; flex-direction:column; gap:1px; margin-inline:-22px; }
.looq-pyv__stripe { position:relative; width:100%; height:177px; }
.looq-pyv__link {
  position:relative; height:100%; width:100%;
  text-decoration:none; color:#fff; padding:40px;
  /* Title pinned to the top, description + arrow pushed to the bottom
     edge — left-aligned for that premium, editorial layout. */
  display:flex; flex-direction:column;
  align-items:flex-start; justify-content:space-between;
  text-align:left;
}
.looq-pyv__title {
  margin:0; padding:0;
  font-family:var(--font-product); font-weight:900;
  font-size:42px; line-height:0.95; color:#fff;
  text-transform:uppercase;
}
.looq-pyv__title span { display:block; }
.looq-pyv__desc {
  /* margin-top:auto anchors the description to the bottom-left of the
     card; padding-right reserves a safe lane so the copy never runs
     under the absolutely-positioned arrow. */
  margin:auto 0 0; padding:0 56px 0 0; max-width:100%;
  font-family:var(--font-body); font-weight:400;
  font-size:13px; line-height:1.3; color:#fff;
}
.looq-pyv__arrow {
  /* Bottom-right corner, baseline-aligned with the last line of the
     description (matches the link's 40px bottom padding). */
  position:absolute; right:40px; bottom:40px;
  display:inline-flex; align-items:center; justify-content:center;
  width:33px; height:14px; color:#fff;
}
{% endstylesheet %}

{% schema %}
{
  "name": "Pick Your Vibe",
  "tag": "section",
  "class": "section--looq-pyv",
  "settings": [
    { "type": "checkbox", "id": "show_headline", "label": "Show 'PICK YOUR VIBE.' headline", "info": "Off by default — already rendered after Best Sellers.", "default": false },
    { "type": "text", "id": "headline_1", "label": "Headline line 1", "default": "PICK" },
    { "type": "text", "id": "headline_2", "label": "Headline line 2", "default": "YOUR VIBE." }
  ],
  "blocks": [
    {
      "type": "stripe",
      "name": "Flavor stripe",
      "limit": 8,
      "settings": [
        { "type": "text",  "id": "title",       "label": "Flavor name",  "default": "STRAWBERRY FLUFF" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Sweet, playful, electric. Happiness in a bottle" },
        { "type": "color", "id": "color",       "label": "Stripe color", "default": "#ed3ea3" },
        { "type": "url",   "id": "url",         "label": "Link" }
      ]
    }
  ],
  "presets": [{
    "name": "Pick Your Vibe",
    "category": "LOOQ",
    "blocks": [
      { "type": "stripe", "settings": { "title": "STRAWBERRY FLUFF", "description": "Sweet, playful, electric. Happiness in a bottle", "color": "#ed3ea3" } },
      { "type": "stripe", "settings": { "title": "VANILLA BREEZE",   "description": "Warm, creamy, soft. Like a deep exhale.",         "color": "#dec85c" } },
      { "type": "stripe", "settings": { "title": "GUMMY YUMMY",      "description": "Fun, fruity, unexpected. The one no one saw coming","color": "#7ed4cc" } },
      { "type": "stripe", "settings": { "title": "VELVET RUSH",      "description": "Rich, smooth, addictive. Your skin will thank you.","color": "#6749c4" } }
    ]
  }]
}
{% endschema %}
