{%- comment -%}
  LOOQ — Bathtub product page (Figma: The Bathtub L/S, The Bathtub Set, The Mini Bathtub Set)
  Layout: vertical-split — white top half (image + back arrow), yellow bottom half (info + size pills + price + ADD TO CART).
{%- endcomment -%}

{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- assign subtitle = product.metafields.custom.subtitle -%}

{%- comment -%}
  Display title — Figma shows "THE BATHTUB" / "THE BATHTUB SET" not the
  Shopify product title (which is "THE MINI TUB" for backwards-compat).
  Override per handle.
{%- endcomment -%}
{%- comment -%}
  Display title: metafield > Shopify product.title with " - {variant}"
  suffix stripped. Words are split by spaces for the per-word span
  rendering below (one <span> per word for line-stacked layout).
{%- endcomment -%}
{%- assign display_title_meta = product.metafields.custom.display_title -%}
{%- if display_title_meta != blank -%}
  {%- assign display_title_words = display_title_meta | split: ' ' -%}
{%- else -%}
  {%- assign clean_title = product.title | split: ' - ' | first | upcase -%}
  {%- assign display_title_words = clean_title | split: ' ' -%}
{%- endif -%}

<section class="looq-product looq-product--bathtub" data-section-id="{{ section.id }}">
  {%- assign parent_collection = product.collections | first -%}
  <nav class="looq-product__crumbs" aria-label="Breadcrumb">
    <a href="{{ routes.root_url }}">HOME</a>
    {%- if parent_collection != blank -%}
      <span class="looq-product__crumb-sep" aria-hidden="true">›</span>
      <a href="{{ parent_collection.url }}">{{ parent_collection.title | upcase }}</a>
    {%- endif -%}
    <span class="looq-product__crumb-sep" aria-hidden="true">›</span>
    <span class="looq-product__crumb-current" aria-current="page">{{ product.title | upcase }}</span>
  </nav>

  <div class="looq-product__media">
    <a class="looq-product__back" href="javascript:history.back()" aria-label="Back">
      <svg width="14" height="22" viewBox="0 0 14 22" fill="none" stroke="#3559ef" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M11 3L3 11l8 8"/>
      </svg>
    </a>

    {%- comment -%} Desktop-only vertical stack of all product.images. {%- endcomment -%}
    <div class="looq-product__stack" aria-hidden="true">
      {%- for img in product.images -%}
        <img src="{{ img | image_url: width: 1200 }}"
             alt="{{ img.alt | default: product.title | escape }}"
             loading="{% if forloop.first %}eager{% else %}lazy{% endif %}">
      {%- endfor -%}
    </div>
    {%- comment -%} Gallery inlined — see looq-product-single for sync-issue context. {%- endcomment -%}
    {%- if product.images.size > 1 -%}
      <div class="looq-gallery" data-gallery>
        <div class="looq-gallery__track" data-gallery-track>
          {%- for img in product.images -%}
            <div class="looq-gallery__slide" data-gallery-slide>
              <img src="{{ img | image_url: width: 800 }}"
                   alt="{{ img.alt | default: product.title | escape }}"
                   loading="{% if forloop.first %}eager{% else %}lazy{% endif %}">
            </div>
          {%- endfor -%}
        </div>
        <div class="looq-gallery__dots" role="tablist" aria-label="Product images">
          {%- for img in product.images -%}
            <button type="button" class="looq-gallery__dot{% if forloop.first %} is-active{% endif %}"
                    data-gallery-dot="{{ forloop.index0 }}"
                    role="tab" aria-label="View image {{ forloop.index }}"></button>
          {%- endfor -%}
        </div>
      </div>
    {%- elsif product.featured_image != blank -%}
      <img class="looq-product__image"
           src="{{ product.featured_image | image_url: width: 800 }}"
           srcset="{{ product.featured_image | image_url: width: 400 }} 400w, {{ product.featured_image | image_url: width: 800 }} 800w"
           sizes="(max-width: 390px) 100vw, 390px"
           alt="{{ product.featured_image.alt | default: product.title | escape }}"
           width="800" height="800" loading="eager">
    {%- endif -%}
  </div>

  <div class="looq-product__info">
    <span class="looq-product__tab" aria-hidden="true"></span>

    <h1 class="looq-product__title">
      {%- for w in display_title_words -%}<span>{{ w }}</span>{%- endfor -%}
    </h1>
    {%- if subtitle != blank -%}
      <p class="looq-product__subtitle">{{ subtitle }}</p>
    {%- endif -%}

    <form method="post" action="{{ routes.cart_add_url }}" id="ProductForm-{{ section.id }}" class="looq-product__form" enctype="multipart/form-data" novalidate="novalidate">
      <input type="hidden" name="form_type" value="product">
      <input type="hidden" name="utf8" value="✓">

      {%- if product.has_only_default_variant == false -%}
        <fieldset class="looq-product__sizes">
          <legend class="visually-hidden">{{ product.options.first }}</legend>
          {%- for value in product.options_with_values.first.values -%}
            {%- assign input_id = 'opt-' | append: section.id | append: '-' | append: forloop.index -%}
            <input type="radio"
                   name="options[{{ product.options.first }}]"
                   value="{{ value | escape }}"
                   id="{{ input_id }}"
                   data-variant-radio
                   {% if value == current_variant.option1 %}checked{% endif %}>
            <label for="{{ input_id }}">{{ value }}</label>
          {%- endfor -%}
        </fieldset>
      {%- endif -%}

      <input type="hidden" name="id" value="{{ current_variant.id }}" data-variant-id-input>

      <div class="looq-product__price-row">
        <span class="looq-product__price" data-price>LE {{ current_variant.price | divided_by: 100.0 | round: 0 }}</span>
        {%- if current_variant.compare_at_price > current_variant.price -%}
          <span class="looq-product__compare" data-compare>LE {{ current_variant.compare_at_price | divided_by: 100.0 | round: 0 }}</span>
        {%- else -%}
          <span class="looq-product__compare" data-compare hidden></span>
        {%- endif -%}
      </div>

      <div class="looq-product__cta-row">
        {%- if current_variant.available -%}
          <button type="submit" class="looq-product__atc" name="add">ADD TO CART</button>
        {%- else -%}
          <button type="button" class="looq-product__atc looq-product__atc--notify" data-notify-open>
            NOTIFY ME WHEN AVAILABLE
          </button>
        {%- endif -%}
      </div>
    </form>
    {%- comment -%} TODO: re-enable once Shopify sync picks up the new snippet
      {% render 'looq-notify-modal', product: product, current_variant: current_variant %}
    {%- endcomment -%}

    {%- comment -%} DESKTOP COPY of the accordion -- inside .looq-product__info. {%- endcomment -%}
    <div class="looq-product__accordion-desktop">
      {% render 'looq-product-accordion', product: product %}
    </div>
  </div>

  {%- comment -%} Variant data for the radio↔price↔hidden-id sync {%- endcomment -%}
  <script type="application/json" data-variant-data>
    {{ product.variants | json }}
  </script>
</section>

{%- comment -%} MOBILE COPY of the accordion -- sibling after </section>. {%- endcomment -%}
<div class="looq-product__accordion-mobile">
  {% render 'looq-product-accordion', product: product %}
</div>

{% stylesheet %}
/* Breadcrumbs + desktop image stack + desktop accordion copy hidden on
   mobile -- desktop snippet flips them. Mobile sibling accordion shows
   via default block display. */
.looq-product--bathtub .looq-product__crumbs,
.looq-product--bathtub .looq-product__stack,
.looq-product__accordion-desktop { display: none; }
.looq-product { width: 100%; max-width: 390px; margin: 0 auto;
  background: #edfc4d; /* matches info-half so the section bg is consistent */ }
.looq-product__media {
  position: relative; background: #fff;
  display: flex; align-items: center; justify-content: center;
  aspect-ratio: 1 / 1;
  padding: 24px 19px;
}
.looq-product__back {
  position: absolute; left: 19px; top: 87px; z-index: 2;  /* below 77px header */
  display: inline-flex; align-items: center; justify-content: center;
  width: 23px; height: 23px;
  background: transparent; border: 0; padding: 0;
}
.looq-product__image { max-width: 80%; max-height: 100%; object-fit: contain; }

/* All values match Figma node 44:1244 (The Bathtub L) exactly.
   Asymmetric horizontal padding: title/subtitle/sizes/price all anchored
   to x=17 (left), buttons row stretches from x=18 to x=364 (right padding
   to panel edge = 26). Use 17 left + 26 right for the panel itself. */
.looq-product__info {
  position: relative;
  background: #edfc4d;
  padding: 37px 26px 39px 17px;  /* top=37 from panel top per Figma; bottom=39 (414-328-47); right=26 */
  min-height: 414px;
  display: flex; flex-direction: column;
}
.looq-product__tab {
  position: absolute; left: 173px; top: 8px;
  width: 44px; height: 6px; background: #ff5c00;
  border-radius: 17px;
}

.looq-product__title {
  margin: 0 0 70px; padding: 0;  /* 70px gap to subtitle baseline per Figma */
  font-family: var(--font-product, 'PP Radio Grotesk', sans-serif);
  font-weight: 900; font-size: 32px; line-height: 1;
  color: #1e1e1e; text-transform: uppercase;
}
.looq-product__title span { display: block; }
.looq-product__subtitle {
  margin: -60px 0 0; padding: 0;  /* offset back: subtitle is 70px below title-start, but title is 2 lines (~64px), so subtitle sits ~6-10px below title */
  font-family: var(--font-italic-display, 'Migra Italic', serif);
  font-style: italic; font-weight: 200;
  font-size: 13px; line-height: 1; color: #1e1e1e;
  opacity: 0.62;
}

.looq-product__form { display: flex; flex-direction: column; flex: 1; }
.looq-product__form > .looq-product__sizes { margin-top: auto; }

.looq-product__sizes {
  display: flex; gap: 18px; padding: 0; margin: 95px 0 28px;
  border: 0; align-items: baseline;
}
.looq-product__sizes input { display: none; }
.looq-product__sizes label {
  font-family: var(--font-product, 'PP Radio Grotesk', sans-serif);
  font-weight: 400; font-size: 15px; line-height: 1;
  color: #1e1e1e;
  opacity: 0.79;
  cursor: pointer;
}
.looq-product__sizes input:checked + label {
  font-weight: 900;
  text-decoration: underline;
  text-underline-offset: 3px;
  text-decoration-thickness: 1px;
}

.looq-product__price-row { display: flex; align-items: baseline; gap: 12px; margin: 27px 0 23px; }
.looq-product__price {
  font-family: var(--font-product, 'PP Radio Grotesk', sans-serif);
  font-weight: 900; font-size: 32px; line-height: 1;
  color: #1e1e1e;
}
.looq-product__compare {
  font-family: var(--font-product, 'PP Radio Grotesk', sans-serif);
  font-weight: 700; font-size: 22px; line-height: 1;
  color: #ff5c00; text-decoration: line-through;
}
.looq-product__compare[hidden] { display: none; }

.looq-product__cta-row {
  display: flex; gap: 10px; margin-top: 0; align-items: stretch;
}
.looq-product__wishlist {
  width: 50px; height: 47px;
  border: 0; background: #1e1e1e;
  display: inline-flex; align-items: center; justify-content: center;
  cursor: pointer; flex-shrink: 0;
  padding: 0;
}
.looq-product__wishlist svg { stroke: #fff; }
.looq-product__atc {
  flex: 1;
  background: #1e1e1e;
  /* ADD TO CART text — Figma spec applies across all product pages */
  color: #FFF;
  font-family: 'PP Radio Grotesk', sans-serif;
  font-size: 16px;
  font-style: normal;
  font-weight: 400;
  line-height: 100%;
  letter-spacing: 6.08px;
  text-transform: uppercase;
  border: 0; padding: 0 16px;
  height: 47px;
  cursor: pointer;
}
.looq-product__atc[disabled] { opacity: 0.6; cursor: not-allowed; }
{% endstylesheet %}

{% javascript %}
if (!customElements.get('looq-product-radios')) {
  class LooqProductRadios extends HTMLElement {
    connectedCallback() {
      this.section = this.closest('section[data-section-id]') || this.closest('section');
      if (!this.section) return;
      this.idInput = this.section.querySelector('[data-variant-id-input]');
      this.priceEl = this.section.querySelector('[data-price]');
      this.compareEl = this.section.querySelector('[data-compare]');
      this.atc = this.section.querySelector('.looq-product__atc');
      const dataEl = this.section.querySelector('[data-variant-data]');
      try {
        this.variants = dataEl ? JSON.parse(dataEl.textContent) : [];
      } catch (e) { this.variants = []; }
      this.section.addEventListener('change', (e) => {
        if (e.target.matches('[data-variant-radio]')) this.update();
      });
    }
    update() {
      const radios = this.section.querySelectorAll('[data-variant-radio]:checked');
      const selected = Array.from(radios).map(r => r.value);
      const variant = this.variants.find(v => {
        const opts = [v.option1, v.option2, v.option3].filter(Boolean);
        return JSON.stringify(opts) === JSON.stringify(selected);
      });
      if (!variant) return;
      if (this.idInput) this.idInput.value = variant.id;
      // variant.price from product.variants | json is in cents; divide by 100 for display
      if (this.priceEl) this.priceEl.textContent = 'LE ' + Math.round(parseFloat(variant.price) / 100);
      if (this.compareEl) {
        const cmp = parseFloat(variant.compare_at_price || 0);
        const price = parseFloat(variant.price);
        if (cmp > price) {
          this.compareEl.textContent = 'LE ' + Math.round(cmp / 100);
          this.compareEl.removeAttribute('hidden');
        } else {
          this.compareEl.setAttribute('hidden', '');
        }
      }
      if (this.atc) {
        if (variant.available) {
          this.atc.removeAttribute('disabled');
          this.atc.textContent = 'ADD TO CART';
        } else {
          this.atc.setAttribute('disabled', '');
          this.atc.textContent = 'SOLD OUT';
        }
      }
    }
  }
  customElements.define('looq-product-radios', LooqProductRadios);

  // Auto-attach the custom element to all bathtub forms
  document.querySelectorAll('.looq-product__form').forEach(f => {
    if (!f.querySelector('looq-product-radios')) {
      const wrap = document.createElement('looq-product-radios');
      f.parentNode.appendChild(wrap);
    }
  });
}
{% endjavascript %}

{% schema %}
{
  "name": "LOOQ Product — Bathtub",
  "tag": "section",
  "class": "section--looq-product-bathtub",
  "settings": [],
  "presets": [
    { "name": "LOOQ Product Bathtub", "category": "LOOQ" }
  ]
}
{% endschema %}
