{% javascript %}
if (!customElements.get('looq-single-radios')) {
  class LooqSingleRadios extends HTMLElement {
    connectedCallback() {
      this.section = this.closest('section[data-section-id]') || this.closest('section');
      if (!this.section) return;
      this.idInput = this.section.querySelector('[data-variant-id-input]');
      this.priceEl = this.section.querySelector('[data-price]');
      this.compareEl = this.section.querySelector('[data-compare]');
      this.atc = this.section.querySelector('.looq-product__atc');
      this.scentNameEl = this.section.querySelector('[data-scent-name]');
      this.scentNameWrap = this.section.querySelector('.looq-product__scent-name');
      try {
        this.variants = JSON.parse(this.section.querySelector('[data-variant-data]').textContent);
        this.scentTokens = JSON.parse(this.section.querySelector('[data-scent-tokens]').textContent);
      } catch (e) { this.variants = []; this.scentTokens = {}; }
      this.section.addEventListener('change', (e) => {
        if (e.target.matches('[data-variant-radio]')) this.update();
      });
    }
    update() {
      const radios = this.section.querySelectorAll('[data-variant-radio]:checked');
      const selected = Array.from(radios).map(r => r.value);
      const variant = this.variants.find(v => {
        const opts = [v.option1, v.option2, v.option3].filter(Boolean);
        return JSON.stringify(opts) === JSON.stringify(selected);
      });
      if (!variant) return;
      if (this.idInput) this.idInput.value = variant.id;
      // Shopify product.variants | json puts price in cents; divide by 100 for display
      if (this.priceEl) this.priceEl.textContent = 'LE ' + Math.round(parseFloat(variant.price) / 100);
      if (this.compareEl) {
        const cmp = parseFloat(variant.compare_at_price || 0);
        if (cmp > parseFloat(variant.price)) {
          this.compareEl.textContent = 'LE ' + Math.round(cmp / 100);
          this.compareEl.removeAttribute('hidden');
        } else {
          this.compareEl.setAttribute('hidden', '');
        }
      }
      const checkedRadio = this.section.querySelector('[data-variant-radio]:checked');
      if (checkedRadio) {
        const handle = checkedRadio.dataset.scentHandle;
        const tokens = this.scentTokens[handle];
        if (tokens) {
          this.section.style.setProperty('--title-color', tokens.title);
          if (this.scentNameWrap) this.scentNameWrap.style.setProperty('--scent-color', tokens.swatch);
          if (this.scentNameEl) this.scentNameEl.textContent = tokens.name;
        }
      }
      if (this.atc) {
        if (variant.available) { this.atc.removeAttribute('disabled'); this.atc.textContent = 'ADD TO CART'; }
        else { this.atc.setAttribute('disabled', ''); this.atc.textContent = 'SOLD OUT'; }
      }
    }
  }
  customElements.define('looq-single-radios', LooqSingleRadios);
  document.querySelectorAll('.looq-product--single').forEach(s => {
    if (!s.querySelector('looq-single-radios')) {
      s.appendChild(document.createElement('looq-single-radios'));
    }
  });
}
{% endjavascript %}

