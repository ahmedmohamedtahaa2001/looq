{%- comment -%}
  Business contact form (LOOQ Creators / Retailers / Affiliates / Distribution).
  Inputs:
    - form_type (required): 'creators' | 'retailers' | 'affiliates' | 'distribution'
  Uses Shopify's built-in {% form 'contact' %} which posts to /contact#contact_form
  and emails the shop's customer-service inbox. Each custom field becomes
  contact[fieldname] in the email body.
  Source content: ~/Downloads/FKILES LOOK/LOOQ WEBSITE CONTENT  - BUSINESS.docx
{%- endcomment -%}

<div class="looq-busform" id="looq-busform-{{ form_type }}">
  {%- assign form_id = 'looq-busform-form-' | append: form_type -%}
  {%- comment -%}
    The form tag's kwargs don't support filter chains (e.g. `id: 'x' | append: y`
    is parsed as the form type being a filter expression — yields "Invalid form
    type" runtime error). Pre-compute the id, then pass as a plain variable.
  {%- endcomment -%}
  {%- form 'contact', class: 'looq-busform__form', id: form_id -%}
    {%- if form.posted_successfully? -%}
      <div class="looq-busform__success">
        <strong>Thanks — we got it.</strong> Our team will reach out shortly.
      </div>
    {%- elsif form.errors -%}
      <div class="looq-busform__errors">
        <strong>Couldn't submit.</strong>
        <ul>
          {%- for field in form.errors -%}
            <li>{{ form.errors.messages[field] }}</li>
          {%- endfor -%}
        </ul>
      </div>
    {%- endif -%}

    <input type="hidden" name="contact[Submission Source]" value="LOOQ {{ form_type | capitalize }} Form">

    <label class="looq-busform__field">
      <span class="looq-busform__label">Full Name *</span>
      <input type="text" name="contact[Full Name]" required>
    </label>

    {%- if form_type == 'retailers' -%}
      <label class="looq-busform__field">
        <span class="looq-busform__label">Store / Business Name *</span>
        <input type="text" name="contact[Store Name]" required>
      </label>
      <label class="looq-busform__field">
        <span class="looq-busform__label">Type of Store *</span>
        <select name="contact[Store Type]" required>
          <option value="">Select…</option>
          <option>Pharmacy</option>
          <option>Supermarket / Mini-market</option>
          <option>Beauty Store</option>
          <option>Lifestyle Store</option>
          <option>Online Store</option>
        </select>
      </label>
    {%- elsif form_type == 'distribution' -%}
      <label class="looq-busform__field">
        <span class="looq-busform__label">Type of Business *</span>
        <select name="contact[Business Type]" required>
          <option value="">Select…</option>
          <option>Distributor</option>
          <option>Wholesaler</option>
          <option>Importer</option>
          <option>Trading Company</option>
        </select>
      </label>
    {%- elsif form_type == 'affiliates' -%}
      <fieldset class="looq-busform__field">
        <legend class="looq-busform__label">How do you plan to sell LOOQ? *</legend>
        <label class="looq-busform__check"><input type="checkbox" name="contact[Sell Through: Social Media]" value="Yes"> Social media</label>
        <label class="looq-busform__check"><input type="checkbox" name="contact[Sell Through: Personal Network]" value="Yes"> Personal network</label>
        <label class="looq-busform__check"><input type="checkbox" name="contact[Sell Through: Small Shop]" value="Yes"> Small shop / kiosk</label>
        <label class="looq-busform__check"><input type="checkbox" name="contact[Sell Through: Online Store]" value="Yes"> Online store / marketplace</label>
        <label class="looq-busform__check"><input type="checkbox" name="contact[Sell Through: Other]" value="Yes"> Other</label>
      </fieldset>
      <label class="looq-busform__field">
        <span class="looq-busform__label">Main Platform (link if online)</span>
        <input type="text" name="contact[Main Platform]" placeholder="Instagram, TikTok, website…">
      </label>
      <label class="looq-busform__field">
        <span class="looq-busform__label">Do you currently sell products?</span>
        <select name="contact[Currently Selling]">
          <option value="">Select…</option>
          <option>Yes</option>
          <option>No, just starting</option>
        </select>
      </label>
    {%- elsif form_type == 'creators' -%}
      <label class="looq-busform__field">
        <span class="looq-busform__label">Content Platform</span>
        <select name="contact[Platform]">
          <option value="">Select…</option>
          <option>Instagram</option>
          <option>TikTok</option>
          <option>YouTube</option>
          <option>Other</option>
        </select>
      </label>
      <label class="looq-busform__field">
        <span class="looq-busform__label">Handle / Channel</span>
        <input type="text" name="contact[Handle]" placeholder="@yourname">
      </label>
      <label class="looq-busform__field">
        <span class="looq-busform__label">Audience Size (approx.)</span>
        <input type="text" name="contact[Audience Size]" placeholder="e.g. 10K, 100K">
      </label>
    {%- endif -%}

    <label class="looq-busform__field">
      <span class="looq-busform__label">Country / City *</span>
      <input type="text" name="contact[Country / City]" required>
    </label>
    <label class="looq-busform__field">
      <span class="looq-busform__label">Contact Number *</span>
      <input type="tel" name="contact[Phone]" required>
    </label>
    <label class="looq-busform__field">
      <span class="looq-busform__label">Email Address *</span>
      <input type="email" name="contact[email]" required>
    </label>

    {%- if form_type == 'distribution' or form_type == 'retailers' or form_type == 'creators' -%}
      <label class="looq-busform__field">
        <span class="looq-busform__label">Anything else? (optional)</span>
        <textarea name="contact[body]" rows="4"></textarea>
      </label>
    {%- endif -%}

    <button type="submit" class="looq-busform__submit">
      {%- if form_type == 'retailers' -%}Become a Retailer
      {%- elsif form_type == 'distribution' -%}Apply as Distributor
      {%- elsif form_type == 'affiliates' -%}Join the Program
      {%- elsif form_type == 'creators' -%}Become a Creator
      {%- else -%}Submit
      {%- endif -%}
    </button>
  {%- endform -%}
</div>

{% stylesheet %}
.looq-busform {
  width:100%; max-width:390px; margin:0 auto;
  padding:24px 24px 40px; background:#fff;
}
.looq-busform__form { display:flex; flex-direction:column; gap:16px; }

.looq-busform__field {
  display:flex; flex-direction:column; gap:6px;
  font-family:var(--font-body, sans-serif);
}
.looq-busform__label {
  font-family:var(--font-product, 'PP Radio Grotesk', sans-serif);
  font-weight:900; font-size:11px; letter-spacing:1.5px;
  color:#1e1e1e; text-transform:uppercase;
}
.looq-busform__form input[type="text"],
.looq-busform__form input[type="email"],
.looq-busform__form input[type="tel"],
.looq-busform__form select,
.looq-busform__form textarea {
  width:100%; box-sizing:border-box;
  padding:12px 14px;
  border:1.5px solid rgba(30,30,30,0.18);
  border-radius:8px;
  background:#fff;
  font-family:var(--font-body, sans-serif);
  font-weight:400; font-size:14px; line-height:1.3;
  color:#1e1e1e;
  transition:border-color 160ms ease;
}
.looq-busform__form input:focus,
.looq-busform__form select:focus,
.looq-busform__form textarea:focus {
  outline:none; border-color:#3559ef;
}
.looq-busform__check {
  display:flex; align-items:center; gap:8px;
  font-family:var(--font-body, sans-serif); font-size:14px;
  color:#1e1e1e; padding:4px 0;
}
.looq-busform__check input[type="checkbox"] {
  width:18px; height:18px; accent-color:#3559ef;
}

.looq-busform__submit {
  display:inline-flex; align-items:center; justify-content:center;
  width:100%; height:50px;
  background:#1e1e1e; color:#fff;
  font-family:var(--font-product, 'PP Radio Grotesk', sans-serif);
  font-weight:400; font-size:16px;
  letter-spacing:6.08px; text-transform:uppercase;
  border:0; border-radius:8px;
  cursor:pointer; margin-top:8px;
  transition:filter 160ms ease;
}
.looq-busform__submit:hover { filter:brightness(1.12); }

.looq-busform__success {
  padding:14px 16px; border-radius:8px;
  background:#3559ef; color:#fff;
  font-family:var(--font-body, sans-serif); font-size:14px;
  line-height:1.4;
}
.looq-busform__errors {
  padding:14px 16px; border-radius:8px;
  background:#fef2f2; color:#b91c1c;
  font-family:var(--font-body, sans-serif); font-size:14px;
}
.looq-busform__errors ul { margin:6px 0 0; padding-left:20px; }
{% endstylesheet %}
