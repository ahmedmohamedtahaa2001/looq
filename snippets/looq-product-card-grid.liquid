{%- comment -%}
  Product card — vertical grid variant (171×234) [v3 nudge]
  Used by: sections/looq-the-goods.liquid, sections/looq-collection-tabs.liquid,
           sections/looq-collection-type.liquid, sections/looq-collection-scent.liquid

  Inputs (any one route):
    - product:    Shopify Product object — drives ALL composition from metafields
                  Reads:
                    product.product_type            → mapped to LOOQ display title
                                                      (Body Wash → BÖDI WÖSH, etc.)
                    custom.scent (metaobject ref)   → name, swatch_color, card_title_color
                    custom.set_size (number)        → "SET OF N" subtitle, no dot
                    custom.accent_color (color)     → overrides scent's card_title_color
                    custom.subtitle (single line)   → fallback subtitle text
    - card_*:     individual demo args (card_title, card_subtitle, card_price,
                  card_image, card_color, card_url) — used while live data isn't wired
{%- endcomment -%}

{%- liquid
  if product != blank and product != nil
    # Live product mode — pull everything from metafields
    assign p_url       = product.url
    assign p_price     = product.price | money_without_trailing_zeros
    assign p_image     = product.featured_image | image_url: width: 400
    assign p_alt       = product.featured_image.alt | default: product.title

    # Title TEXT comes from real Shopify product data:
    #   1. custom.display_title metafield (per-product Admin override)
    #   2. product.title with " - {variant}" suffix stripped, upcased
    # Per user request -- replaces the previous handle-based hardcoded
    # mapping. Now adding a new product family in Admin doesn't require
    # a code change.
    assign h = product.handle | downcase
    assign display_title_meta = product.metafields.custom.display_title
    if display_title_meta != blank
      assign p_title = display_title_meta
    else
      assign p_title = product.title | split: ' - ' | first | upcase
    endif

    # Resolve scent metaobject (if linked)
    assign scent_obj = product.metafields.custom.scent.value

    # Title + dot color resolution
    assign p_color = '#1e1e1e'
    if scent_obj != blank
      assign scent_card_color = scent_obj.card_title_color | default: scent_obj.swatch_color
      assign p_color = scent_card_color
    endif
    # Per-product override (for sets / bathtub etc.)
    assign override_color = product.metafields.custom.accent_color
    if override_color != blank
      assign p_color = override_color
    endif

    # Dot color (only for scent products) = swatch_color
    assign p_dot_color = ''
    if scent_obj != blank
      assign p_dot_color = scent_obj.swatch_color
    endif

    # Subtitle: SET OF N > scent name > custom subtitle > product type
    assign set_size = product.metafields.custom.set_size
    if set_size != blank
      assign p_subtitle = 'SET OF ' | append: set_size
      assign is_set_subtitle = true
      assign p_dot_color = ''
    elsif scent_obj != blank
      assign p_subtitle = scent_obj.name | upcase
      assign is_set_subtitle = false
    else
      assign sub_meta = product.metafields.custom.subtitle
      if sub_meta != blank
        assign p_subtitle = sub_meta | upcase
      else
        assign p_subtitle = ''
      endif
      assign is_set_subtitle = true
    endif
  elsif card_title != blank
    # Demo card mode (legacy)
    assign p_url       = card_url   | default: '#'
    assign p_title     = card_title
    assign p_subtitle  = card_subtitle | default: ''
    assign p_price     = card_price | default: ''
    assign p_image     = card_image | asset_url
    assign p_alt       = card_title
    assign p_color     = card_color | default: '#6749c4'
    assign p_dot_color = card_color | default: '#6749c4'
    assign subtitle_words = p_subtitle | split: ' '
    assign is_set_subtitle = false
    if subtitle_words.size > 2
      assign is_set_subtitle = true
      assign p_dot_color = ''
    endif
  endif

  # First available variant ID for the inline cart-add form on the card.
  # selected_or_first_available_variant prefers an in-stock variant; falls
  # back to the first one. Empty string when no `product` is provided.
  assign p_variant_id = ''
  if product != blank and product != nil
    assign p_variant_id = product.selected_or_first_available_variant.id
  endif
-%}

<a class="product-card-grid" href="{{ p_url }}" aria-label="{{ p_title }}" style="--card-accent: {{ p_color }};{% if p_dot_color != blank %} --card-dot: {{ p_dot_color }};{% endif %}">
  <div class="product-card-grid__media">
    <img src="{{ p_image }}" alt="{{ p_alt | escape }}" width="171" height="218" loading="lazy">
  </div>

  <div class="product-card-grid__info">
    <div class="product-card-grid__heading">
      <span class="product-card-grid__title">{{ p_title }}</span>
      {%- if p_subtitle != blank -%}
        <span class="product-card-grid__subtitle{% if is_set_subtitle %} product-card-grid__subtitle--set{% endif %}">
          {%- if p_dot_color != blank -%}<span class="product-card-grid__dot" aria-hidden="true"></span>{%- endif -%}
          {{ p_subtitle }}
        </span>
      {%- endif -%}
      <span class="product-card-grid__price">{{ p_price }}</span>
    </div>

    <div class="product-card-grid__actions">
      {%- comment -%} Eye / quick-view icon removed per UX cleanup.
        Cart icon now AJAX-adds the first available variant (handled by the
        delegated click listener in sections/looq-cart-drawer.liquid). {%- endcomment -%}
      <button type="button" class="product-card-grid__action"
              data-add-to-cart
              data-variant-id="{{ p_variant_id }}"
              aria-label="Add {{ p_title }} to cart">
        {% render 'looq-icon-cart' %}
      </button>
    </div>
  </div>
</a>

