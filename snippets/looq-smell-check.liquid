{%- comment -%}
  Smell Check modal — opens when user taps the (i) next to CHOOSE YOUR SCENT
  on any product page (single + bundle). Shows the 4 LOOQ scents with their
  swatch dot, name, and 2-line description, plus the pink "Pick the mix
  that matches your LOOQ" hint pill at the bottom.
  Source: Figma Image #90 (Smell Check popup).

  This snippet is rendered ONCE globally (from the cart drawer section)
  so it's available on every page. Markup is hidden by default; JS toggles
  the `is-open` class when any [data-smell-check-open] button is clicked.
{%- endcomment -%}

<div class="looq-smell" id="looq-smell" aria-hidden="true" aria-modal="true" role="dialog" aria-labelledby="looq-smell-title">
  <div class="looq-smell__backdrop" data-smell-check-close></div>
  <div class="looq-smell__sheet" role="document">
    <span class="looq-smell__handle" aria-hidden="true"></span>
    <button type="button" class="looq-smell__close" data-smell-check-close aria-label="Close">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <path d="M1 1l12 12M13 1L1 13" stroke="#1e1e1e" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>

    <h2 class="looq-smell__title" id="looq-smell-title">SMELL CHECK</h2>
    <p class="looq-smell__tagline">Not sure what to pick?<br>Here's the LOOQ scent cheat sheet.</p>

    <ul class="looq-smell__list" role="list">
      <li class="looq-smell__item">
        <span class="looq-smell__dot" style="background:#ebd35d;" aria-hidden="true"></span>
        <div class="looq-smell__text">
          <strong>VANILLA BREEZE</strong>
          <span>Warm, creamy, soft.<br>Like a deep exhale.</span>
        </div>
      </li>
      <li class="looq-smell__item">
        <span class="looq-smell__dot" style="background:#6749c4;" aria-hidden="true"></span>
        <div class="looq-smell__text">
          <strong>VELVET RUSH</strong>
          <span>Floral, fruity, and feminine.<br>A mixture of sweet &amp; soft.</span>
        </div>
      </li>
      <li class="looq-smell__item">
        <span class="looq-smell__dot" style="background:#ed3ea3;" aria-hidden="true"></span>
        <div class="looq-smell__text">
          <strong>STRAWBERRY FLUFF</strong>
          <span>Sweet, playful, electric.<br>Happiness in a bottle.</span>
        </div>
      </li>
      <li class="looq-smell__item">
        <span class="looq-smell__dot" style="background:#61dddb;" aria-hidden="true"></span>
        <div class="looq-smell__text">
          <strong>GUMMY YUMMY</strong>
          <span>Fun, fruity, unexpected.<br>The one no one saw coming.</span>
        </div>
      </li>
    </ul>

    <p class="looq-smell__hint">Pick the mix that matches your LOOQ</p>
  </div>
</div>

{% stylesheet %}
.looq-smell {
  position: fixed; inset: 0; z-index: 1500;
  display: none;
}
.looq-smell[aria-hidden="false"] { display: block; }
.looq-smell__backdrop {
  position: absolute; inset: 0;
  background: rgba(0, 0, 0, 0.55);
  opacity: 0;
  transition: opacity 240ms ease;
}
.looq-smell[aria-hidden="false"] .looq-smell__backdrop { opacity: 1; }

.looq-smell__sheet {
  position: absolute; left: 50%; bottom: 0;
  transform: translate(-50%, 100%);
  width: 100%; max-width: 390px;
  background: #fff;
  border-radius: 18px 18px 0 0;
  padding: 22px 22px 30px;
  box-sizing: border-box;
  transition: transform 280ms cubic-bezier(.22, 1, .36, 1);
  max-height: 86vh;
  overflow-y: auto;
}
.looq-smell[aria-hidden="false"] .looq-smell__sheet {
  transform: translate(-50%, 0);
}
.looq-smell__handle {
  display: block;
  width: 36px; height: 4px;
  background: #6749c4;
  border-radius: 2px;
  margin: 0 auto 18px;
}
.looq-smell__close {
  position: absolute; top: 22px; right: 22px;
  width: 24px; height: 24px;
  padding: 0; border: 0; background: transparent;
  cursor: pointer;
  display: inline-flex; align-items: center; justify-content: center;
}
.looq-smell__title {
  margin: 0 0 8px; padding: 0;
  font-family: var(--font-product, 'PP Radio Grotesk', sans-serif);
  font-weight: 900; font-size: 22px; line-height: 1;
  color: #1e1e1e;
  text-transform: uppercase;
}
.looq-smell__tagline {
  margin: 0 0 18px; padding: 0;
  font-family: var(--font-product, 'PP Radio Grotesk', sans-serif);
  font-weight: 400; font-size: 13px; line-height: 1.4;
  color: rgba(30, 30, 30, 0.72);
}

.looq-smell__list {
  list-style: none; margin: 0 0 18px; padding: 0;
  display: flex; flex-direction: column;
}
.looq-smell__item {
  display: flex; align-items: flex-start; gap: 14px;
  padding: 14px 0;
  border-bottom: 1px solid rgba(30, 30, 30, 0.08);
}
.looq-smell__item:last-child { border-bottom: 0; }
.looq-smell__dot {
  flex-shrink: 0;
  width: 32px; height: 32px; border-radius: 50%;
  margin-top: 2px;
}
.looq-smell__text {
  display: flex; flex-direction: column; gap: 4px;
}
.looq-smell__text strong {
  font-family: var(--font-product, 'PP Radio Grotesk', sans-serif);
  font-weight: 900; font-size: 14px; line-height: 1;
  color: #1e1e1e;
  text-transform: uppercase;
}
.looq-smell__text span {
  font-family: var(--font-product, 'PP Radio Grotesk', sans-serif);
  font-weight: 400; font-size: 12px; line-height: 1.4;
  color: rgba(30, 30, 30, 0.72);
}

.looq-smell__hint {
  margin: 0; padding: 14px 18px;
  text-align: center;
  background: rgba(237, 62, 163, 0.12);
  border-radius: 30px;
  font-family: var(--font-product, 'PP Radio Grotesk', sans-serif);
  font-weight: 400; font-size: 13px; line-height: 1.3;
  color: #1e1e1e;
}

/* (i) info button used inline next to "CHOOSE YOUR SCENT" */
.looq-info-btn {
  display: inline-flex; align-items: center; justify-content: center;
  width: 18px; height: 18px; padding: 0;
  background: transparent; border: 0; cursor: pointer;
  color: rgba(30, 30, 30, 0.65);
  transition: color 160ms ease, transform 160ms ease;
  vertical-align: middle;
  margin-left: 6px;
}
.looq-info-btn:hover { color: #1e1e1e; transform: scale(1.1); }
.looq-info-btn svg { width: 100%; height: 100%; display: block; }
{% endstylesheet %}

<script>
(function(){
  var modal = document.getElementById('looq-smell');
  if (!modal) return;
  function open() {
    modal.setAttribute('aria-hidden', 'false');
    document.documentElement.style.overflow = 'hidden';
  }
  function close() {
    modal.setAttribute('aria-hidden', 'true');
    document.documentElement.style.overflow = '';
  }
  document.addEventListener('click', function(e){
    var opener = e.target.closest('[data-smell-check-open]');
    if (opener) { e.preventDefault(); open(); return; }
    var closer = e.target.closest('[data-smell-check-close]');
    if (closer) { e.preventDefault(); close(); return; }
  });
  document.addEventListener('keydown', function(e){
    if (e.key === 'Escape' && modal.getAttribute('aria-hidden') === 'false') close();
  });
})();
</script>
