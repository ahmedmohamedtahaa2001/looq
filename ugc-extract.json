"{\n  \"sectionOpenTag\": \"<section class=\\\"looq-ugc\\\" data-section-id=\\\"template--19859227541613__ugc-videos\\\">\",\n  \"head\": \"<header class=\\\"looq-ugc__head\\\">\\n    <h2 class=\\\"looq-ugc__title\\\">\\n      <span class=\\\"looq-ugc__title-1\\\">LOOQ</span>\\n      <span class=\\\"looq-ugc__title-2\\\">IN REAL LIFE</span>\\n    </h2>\\n    <p class=\\\"looq-ugc__tagline\\\">Real people. Real routines. Real good smells.</p>\\n  </header>\",\n  \"carouselOpen\": \"<div class=\\\"looq-ugc__carousel\\\" data-ugc-carousel=\\\"\\\" data-ugc-init=\\\"1\\\">\",\n  \"pag\": \"<div class=\\\"looq-ugc__dots-pagination\\\" role=\\\"tablist\\\" aria-label=\\\"Video carousel pagination\\\"><button type=\\\"button\\\" class=\\\"looq-ugc__pag-dot\\\" data-ugc-dot=\\\"0\\\" role=\\\"tab\\\" aria-label=\\\"Slide 1\\\"></button><button type=\\\"button\\\" class=\\\"looq-ugc__pag-dot is-active\\\" data-ugc-dot=\\\"1\\\" role=\\\"tab\\\" aria-label=\\\"Slide 2\\\"></button><button type=\\\"button\\\" class=\\\"looq-ugc__pag-dot\\\" data-ugc-dot=\\\"2\\\" role=\\\"tab\\\" aria-label=\\\"Slide 3\\\"></button><button type=\\\"button\\\" class=\\\"looq-ugc__pag-dot\\\" data-ugc-dot=\\\"3\\\" role=\\\"tab\\\" aria-label=\\\"Slide 4\\\"></button><button type=\\\"button\\\" class=\\\"looq-ugc__pag-dot\\\" data-ugc-dot=\\\"4\\\" role=\\\"tab\\\" aria-label=\\\"Slide 5\\\"></button><button type=\\\"button\\\" class=\\\"looq-ugc__pag-dot\\\" data-ugc-dot=\\\"5\\\" role=\\\"tab\\\" aria-label=\\\"Slide 6\\\"></button></div>\",\n  \"scriptCount\": 1,\n  \"scripts\": [\n    \"\\n(function(){\\n  document.querySelectorAll('[data-ugc-carousel]:not([data-ugc-init])').forEach(function(carousel){\\n    carousel.setAttribute('data-ugc-init', '1');\\n    var track = carousel.querySelector('[data-ugc-track]');\\n    var dots = carousel.querySelectorAll('[data-ugc-dot]');\\n    var cards = carousel.querySelectorAll('[data-ugc-card]');\\n    if (!track) return;\\n\\n    // Shared play routine: pauses every other clip, marks this one as\\n    // started (so the big centered play is replaced by the small bottom-left\\n    // toggle) and playing, then plays. Custom controls only (no native\\n    // controls bar) so fullscreen / download / PiP never appear.\\n    function startPlay(wrap, video){\\n      carousel.querySelectorAll('[data-ugc-video]').forEach(function(v){\\n        if (v !== video && !v.paused) {\\n          v.pause();\\n          v.closest('.looq-ugc__video-wrap').classList.remove('is-playing');\\n        }\\n      });\\n      wrap.classList.add('is-started', 'is-playing');\\n      video.muted = false;\\n      video.play().catch(function(){\\n        // Autoplay blocked — fall back to muted playback\\n        video.muted = true;\\n        video.play();\\n      });\\n    }\\n\\n    // Big centered play button — first start only.\\n    carousel.querySelectorAll('[data-ugc-play]').forEach(function(btn){\\n      btn.addEventListener('click', function(e){\\n        e.preventDefault();\\n        var wrap = btn.closest('.looq-ugc__video-wrap');\\n        var video = wrap.querySelector('[data-ugc-video]');\\n        if (video) startPlay(wrap, video);\\n      });\\n    });\\n\\n    // Small bottom-left toggle — flips play/pause from the same spot.\\n    carousel.querySelectorAll('[data-ugc-toggle]').forEach(function(btn){\\n      btn.addEventListener('click', function(e){\\n        e.preventDefault();\\n        e.stopPropagation();\\n        var wrap = btn.closest('.looq-ugc__video-wrap');\\n        var video = wrap.querySelector('[data-ugc-video]');\\n        if (!video) return;\\n        if (video.paused) {\\n          startPlay(wrap, video);\\n        } else {\\n          video.pause();\\n          wrap.classList.remove('is-playing');\\n        }\\n      });\\n    });\\n\\n    // Mute toggle button — toggles video.muted and swaps SVG icon state\\n    // via the parent's `is-muted` class. The CSS shows on/off icons\\n    // based on this class.\\n    carousel.querySelectorAll('[data-ugc-mute]').forEach(function(btn){\\n      btn.addEventListener('click', function(e){\\n        e.preventDefault();\\n        e.stopPropagation();\\n        var wrap = btn.closest('.looq-ugc__video-wrap');\\n        var video = wrap && wrap.querySelector('[data-ugc-video]');\\n        if (!video) return;\\n        video.muted = !video.muted;\\n        wrap.classList.toggle('is-muted', video.muted);\\n      });\\n    });\\n\\n    // Pagination dot click → scroll to card\\n    dots.forEach(function(dot){\\n      dot.addEventListener('click', function(){\\n        var i = parseInt(dot.dataset.ugcDot, 10);\\n        var card = cards[i];\\n        if (card) track.scrollTo({ left: card.offsetLeft - track.offsetLeft, behavior: 'smooth' });\\n      });\\n    });\\n\\n    // Active card + dot updates on scroll. The centered card gets is-active\\n    // (which CSS scales up + un-fades), all others get the dim/scale-down state.\\n    function updateActive() {\\n      var center = track.scrollLeft + track.clientWidth / 2;\\n      var nearestIdx = 0, nearestDist = Infinity;\\n      cards.forEach(function(c, i){\\n        var cardCenter = c.offsetLeft + c.offsetWidth / 2 - track.offsetLeft;\\n        var d = Math.abs(cardCenter - center);\\n        if (d < nearestDist) { nearestDist = d; nearestIdx = i; }\\n      });\\n      cards.forEach(function(c, i){ c.classList.toggle('is-active', i === nearestIdx); });\\n      dots.forEach(function(d, i){ d.classList.toggle('is-active', i === nearestIdx); });\\n    }\\n\\n    var ticking = false;\\n    track.addEventListener('scroll', function(){\\n      if (ticking) return;\\n      ticking = true;\\n      requestAnimationFrame(function(){ updateActive(); ticking = false; });\\n    });\\n    // Initial run + scroll to first card centered\\n    requestAnimationFrame(function(){\\n      if (cards.length > 0) {\\n        var first = cards[0];\\n        track.scrollLeft = first.offsetLeft - track.offsetLeft - (track.clientWidth - first.offsetWidth) / 2;\\n      }\\n      updateActive();\\n    });\\n  });\\n})();\\n\"\n  ]\n}"